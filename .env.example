# Gemini API Key for Nano Banana image generation
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key for GPT Image 2 (optional — only needed when backend=openai)
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace Token (optional, for MMAudio Space access)
HF_TOKEN=your_huggingface_token_here

# Optional: Set device preference (cuda, cpu, mps)
DEVICE=cuda

# Optional: Model cache directory
MODEL_CACHE_DIR=./models
